# Server
NODE_ENV=development
PORT=3002
API_KEY=your-api-key-here

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/content_jinee?schema=public

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# OpenAI (or compatible API like Groq, Together, etc.)
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o
OPENAI_BASE_URL=

# AI Provider (openai | ollama)
AI_PROVIDER=openai

# Ollama (Local LLM)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1

# Encryption (for stored credentials)
ENCRYPTION_KEY=generate-a-64-char-hex-string-here

# Browser Automation
BROWSER_HEADLESS=true
BROWSER_MAX_CONTEXTS=3
SCREENSHOT_DIR=./screenshots
